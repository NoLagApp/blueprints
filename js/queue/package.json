{
  "name": "@nolag/queue",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "description": "Real-time job queue SDK for NoLag — job lifecycle, progress tracking, worker management",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "browser": "./dist/browser.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "browser": {
        "types": "./dist/browser.d.ts",
        "default": "./dist/browser.js"
      },
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      },
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NoLagApp/blueprints.git",
    "directory": "js/queue"
  },
  "author": "NoLag",
  "license": "MIT",
  "homepage": "https://nolag.app",
  "devDependencies": {
    "@nolag/js-sdk": "^1.1.0"
  },
  "peerDependencies": {
    "@nolag/js-sdk": "^1.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
